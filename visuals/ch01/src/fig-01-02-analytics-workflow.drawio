<mxfile>
  <diagram name="Analytics Workflow" id="fig0102">
    <mxGraphModel dx="1024" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Row 1: Stages 1-3 (left to right) -->

        <!-- Stage 1 -->
        <mxCell id="10" value="1. Define the question" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A5276;fontColor=#FFFFFF;strokeColor=#1A5276;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Translate the business need into&#xa;a specific analytical question" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="10">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow 1-2 -->
        <mxCell id="15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#5D6D7E;strokeWidth=1.5;" edge="1" source="10" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 2 -->
        <mxCell id="20" value="2. Access the data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A5276;fontColor=#FFFFFF;strokeColor=#1A5276;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="Identify sources, extract&#xa;relevant tables and columns" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="20">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow 2-3 -->
        <mxCell id="25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#5D6D7E;strokeWidth=1.5;" edge="1" source="20" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 3 -->
        <mxCell id="30" value="3. Prepare and clean" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A5276;fontColor=#FFFFFF;strokeColor=#1A5276;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="660" y="60" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Resolve missing values, duplicates,&#xa;inconsistent formatting" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="30">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow 3 down to 4 -->
        <mxCell id="35" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5D6D7E;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="30" target="40" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Row 2: Stages 4-6 (right to left) -->

        <!-- Stage 4 -->
        <mxCell id="40" value="4. Analyze" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17A589;fontColor=#FFFFFF;strokeColor=#17A589;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="660" y="210" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="41" value="Summarize, compare, model,&#xa;detect anomalies" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="40">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow 4-5 -->
        <mxCell id="45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#5D6D7E;strokeWidth=1.5;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="40" target="50" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 5 -->
        <mxCell id="50" value="5. Visualize and present" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17A589;fontColor=#FFFFFF;strokeColor=#17A589;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="350" y="210" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="Charts, dashboards, interactive&#xa;reports for stakeholders" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="50">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow 5-6 -->
        <mxCell id="55" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#5D6D7E;strokeWidth=1.5;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="50" target="60" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 6 -->
        <mxCell id="60" value="6. Communicate findings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F39C12;fontColor=#FFFFFF;strokeColor=#F39C12;fontSize=12;fontStyle=1;fontFamily=Arial;arcSize=20;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="61" value="Memoranda, presentations,&#xa;and reports to decision makers" style="text;html=1;align=center;verticalAlign=middle;fontColor=#FFFFFF;fontSize=10;fontFamily=Arial;" vertex="1" parent="60">
          <mxGeometry x="15" y="30" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Chapter mapping note -->
        <mxCell id="70" value="Chapters 2-3 address stages 1-2. Chapters 4-12 address stages 3-4. Chapters 13-16 address stage 5. All chapters practice stage 6." style="text;html=1;align=center;verticalAlign=middle;fontColor=#5D6D7E;fontSize=10;fontFamily=Arial;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="160" y="340" width="640" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
